<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Configuración del tema base de la aplicación (Material 3) -->
    <style name="Base.Theme.ProyectoAndroid" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores primarios y secundarios definidos anteriormente en colors.xml -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
    </style>

    <!-- Usamos el tema Base para el proyecto completo -->
    <style name="Theme.ProyectoAndroid" parent="Base.Theme.ProyectoAndroid" />
</resources>